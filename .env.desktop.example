# Tauri 桌面应用用户配置（首次运行后复制到应用数据目录）
# macOS: ~/Library/Application Support/com.huoke.desktop/.env.desktop
# Windows: %APPDATA%\com.huoke.desktop\.env.desktop

# Chrome 插件 + local-service 架构（无 Python 后端）
VITE_LOCAL_SERVICE_URL=http://127.0.0.1:18766
HUOKE_DAILY_REPLY_QUOTA=50

# 云端客户后台（盈小蚁 H5）嵌入
VITE_PORTAL_ENABLED=1
VITE_PORTAL_BASE_URL=https://www.tanjiyunai.com

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
