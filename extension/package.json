{
  "name": "huoke-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Huoke Chrome extension — browser execution layer",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build && node scripts/verify-dist.mjs",
    "verify": "node scripts/verify-dist.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.268",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
