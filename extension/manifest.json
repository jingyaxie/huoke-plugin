{
  "manifest_version": 3,
  "name": "Huoke 获客助手",
  "version": "0.1.2",
  "description": "Huoke browser execution layer — connects to local Rust service",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Huoke",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "windows", "system.display", "scripting", "alarms", "offscreen", "debugger"],
  "host_permissions": [
    "http://127.0.0.1:18766/*",
    "http://localhost:18766/*",
    "https://www.douyin.com/*",
    "https://*.douyin.com/*",
    "https://www.xiaohongshu.com/*",
    "https://*.xiaohongshu.com/*",
    "https://www.kuaishou.com/*",
    "https://*.kuaishou.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.douyin.com/*",
        "https://*.douyin.com/*",
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*",
        "https://www.kuaishou.com/*",
        "https://*.kuaishou.com/*"
      ],
      "js": ["src/injected/network-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.douyin.com/*",
        "https://*.douyin.com/*",
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*",
        "https://www.kuaishou.com/*",
        "https://*.kuaishou.com/*"
      ],
      "js": ["src/content/bootstrap.js", "src/content/index.ts"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected/network-hook.js"],
      "matches": [
        "https://www.douyin.com/*",
        "https://*.douyin.com/*",
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*",
        "https://www.kuaishou.com/*",
        "https://*.kuaishou.com/*"
      ]
    }
  ]
}
